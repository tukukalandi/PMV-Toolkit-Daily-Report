rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tukukalandi@gmail.com'
      );
    }

    function isValidReport(data) {
      return data.keys().hasAll(['officeName', 'openingBalance', 'articlesReceived', 'articlesDelivered', 'articlesPending', 'reportDate', 'createdAt', 'updatedAt', 'pendingReason'])
        && data.officeName is string && data.officeName.size() <= 200
        && data.openingBalance is number && data.openingBalance >= 0
        && data.articlesReceived is number && data.articlesReceived >= 0
        && data.articlesDelivered is number && data.articlesDelivered >= 0
        && data.articlesPending is number
        && data.reportDate is string && data.reportDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.pendingReason is string
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }

    match /reports/{reportId} {
      // Allow anyone to create valid reports and check for duplicates/balances
      allow create: if isValidReport(request.resource.data) || isAdmin();
      allow read, list: if true;
      
      // Protect sensitive operations
      allow update, delete: if isAdmin();
    }
  }
}
