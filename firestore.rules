rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tukukalandi@gmail.com' && 
        request.auth.token.email_verified == true
      );
    }

    function isValidReport(data) {
      return data.keys().hasAll(['officeName', 'openingBalance', 'articlesReceived', 'articlesDelivered', 'articlesPending', 'reportDate', 'createdAt', 'updatedAt'])
        && data.officeName is string && data.officeName.size() <= 200
        && data.openingBalance is number && data.openingBalance >= 0
        && data.articlesReceived is number && data.articlesReceived >= 0
        && data.articlesDelivered is number && data.articlesDelivered >= 0
        && data.articlesPending is number
        && data.reportDate is string && data.reportDate.size() <= 10
        && (data.get('pendingReason', '') is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /reports/{reportId} {
      allow create: if isValidReport(request.resource.data);
      
      allow read, list: if isAdmin();

      allow delete: if isAdmin();
    }
  }
}
